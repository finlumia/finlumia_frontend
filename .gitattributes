# Normalize line endings (recommended for cross-platform Node/Next.js repos)
* text=auto eol=lf

# Explicit text sources
*.css   text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.mjs   text eol=lf
*.ps1   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Shell scripts (LF no repositório; evita quebra no Linux ao clonar no Windows)
*.sh    text eol=lf
finlumia.sh text eol=lf

# Binary assets (do not diff as text)
*.ico   binary
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.ttf   binary
*.pdf   binary

# SVG: text for merge-friendly diffs (Finlumia logo is SVG)
*.svg   text eol=lf

# Lockfile — always LF to avoid noisy diffs on Windows
package-lock.json text eol=lf
