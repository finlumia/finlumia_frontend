# ─────────────────────────────────────────────────────────────
# Finlumia Frontend — Variáveis de ambiente
# Copie para .env.local e preencha os valores do seu ambiente.
# Nunca comite .env.local ou valores reais de produção.
# ─────────────────────────────────────────────────────────────

# ── PROXY SERVER-TO-SERVER (sem NEXT_PUBLIC — nunca expostas ao browser) ─────
# Todas as chamadas da UI passam pelo proxy Next.js (/proxy/<serviço>/*).
# O proxy lê essas variáveis server-side e encaminha ao backend real.
# O browser nunca vê URLs de backend.

# Local
#SERVICE_IDENTIFICATION_URL=http://localhost:28083
#SERVICE_MOVIMENTATION_URL=http://localhost:28084
#SERVICE_DOCUMENT_URL=http://localhost:28085
#SERVICE_CONFIGURATOR_URL=http://localhost:28081
#SERVICE_SUPPORT_URL=http://localhost:28082

# Produção — subdomínio dedicado por serviço (ver registros DNS em thiagobenevide.com)
SERVICE_IDENTIFICATION_URL=https://apifinlumia.identification.thiagobenevide.com
SERVICE_MOVIMENTATION_URL=https://apifinlumia.movimentation .thiagobenevide.com
SERVICE_DOCUMENT_URL=https://apifinlumia.document.thiagobenevide.com
SERVICE_CONFIGURATOR_URL=https://apifinlumia.configurator.thiagobenevide.com
SERVICE_SUPPORT_URL=https://apifinlumia.docs.thiagobenevide.com

# ── STORAGE DE ANEXOS (upload direto browser→MinIO/S3, fora do proxy) ────────
# Único domínio que o browser acessa fora do same-origin — precisa estar
# liberado na CSP (connect-src/img-src/media-src, ver src/middleware.ts).
# Local
#STORAGE_ORIGIN=http://localhost:9000
# Produção
STORAGE_ORIGIN=https://apifinlumia-storage.thiagobenevide.com

# ── AUTENTICAÇÃO GOOGLE OAUTH ─────────────────────────────────
# Client ID público do Google Cloud Console (sem segredo — apenas o ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── FEATURE FLAGS (opcional) ──────────────────────────────────
NEXT_PUBLIC_FEATURE_IMPORT_ENABLED=false
NEXT_PUBLIC_FEATURE_MFA_ENABLED=true
