# ─────────────────────────────────────────────────────────────
# Finlumia Frontend — Variáveis de ambiente
# Copie para .env.local e preencha os valores do seu ambiente.
# Nunca comite .env.local ou valores reais de produção.
# ─────────────────────────────────────────────────────────────

# Ambiente ativo: local | homologation | production
NEXT_PUBLIC_APP_ENV=local

# Versão da API (prefixo de path: /v1, /v2...)
NEXT_PUBLIC_API_VERSION=v1

# ── LOCAL (desenvolvimento) ───────────────────────────────────
# Assumindo um gateway único em :8080 roteando por path.
# Substitua pelas portas individuais se usar microserviços separados.

NEXT_PUBLIC_SERVICE_IDENTIFICATION_LOCAL=http://localhost:8080/identification
NEXT_PUBLIC_SERVICE_MOVIMENTATION_LOCAL=http://localhost:8080/movimentation
NEXT_PUBLIC_SERVICE_DOCUMENT_LOCAL=http://localhost:8080/document
NEXT_PUBLIC_SERVICE_CONFIGURATOR_LOCAL=http://localhost:8080/configurator

# ── HOMOLOGAÇÃO ───────────────────────────────────────────────

NEXT_PUBLIC_SERVICE_IDENTIFICATION_HOMOLOGATION=https://api-hom.finlumia.com/identification
NEXT_PUBLIC_SERVICE_MOVIMENTATION_HOMOLOGATION=https://api-hom.finlumia.com/movimentation
NEXT_PUBLIC_SERVICE_DOCUMENT_HOMOLOGATION=https://api-hom.finlumia.com/document
NEXT_PUBLIC_SERVICE_CONFIGURATOR_HOMOLOGATION=https://api-hom.finlumia.com/configurator

# ── PRODUÇÃO ──────────────────────────────────────────────────

NEXT_PUBLIC_SERVICE_IDENTIFICATION_PRODUCTION=https://api.finlumia.com/identification
NEXT_PUBLIC_SERVICE_MOVIMENTATION_PRODUCTION=https://api.finlumia.com/movimentation
NEXT_PUBLIC_SERVICE_DOCUMENT_PRODUCTION=https://api.finlumia.com/document
NEXT_PUBLIC_SERVICE_CONFIGURATOR_PRODUCTION=https://api.finlumia.com/configurator

# ── AUTENTICAÇÃO GOOGLE OAUTH ─────────────────────────────────
# Client ID público do Google Cloud Console
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── FEATURE FLAGS (opcional) ──────────────────────────────────
# Controle de funcionalidades em desenvolvimento
NEXT_PUBLIC_FEATURE_IMPORT_ENABLED=false
NEXT_PUBLIC_FEATURE_MFA_ENABLED=true
